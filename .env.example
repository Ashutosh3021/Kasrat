# ─────────────────────────────────────────────────────────────────────────────
# KASRAT – Environment Variables
# Copy this file to .env for local development.
# For production (GitHub Pages), add these as GitHub Actions secrets:
#   Repository → Settings → Secrets and variables → Actions → New repository secret
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────────

# Supabase project URL
# Found in: Supabase Dashboard → Project Settings → API → Project URL
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anonymous (public) key
# Found in: Supabase Dashboard → Project Settings → API → Project API keys → anon / public
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# OAuth redirect base URL (the code appends /# automatically).
# Must ALSO be added to: Supabase Dashboard → Authentication → URL Configuration → Redirect URLs
#   Add both:  https://ashutosh3021.github.io/Kasrat/#
#              http://localhost:5173/Kasrat/#
#
# GitHub Pages (production):
VITE_SUPABASE_REDIRECT_URL=https://ashutosh3021.github.io/Kasrat
#
# Local development — change to:
# VITE_SUPABASE_REDIRECT_URL=http://localhost:5173/Kasrat
