# ─────────────────────────────────────────────────────────────────────────────
# KASRAT – Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase project URL
# Found in: Supabase Dashboard → Project Settings → API → Project URL
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anonymous (public) key
# Found in: Supabase Dashboard → Project Settings → API → Project API keys → anon / public
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# OAuth redirect URL — where Supabase sends the user after Google sign-in.
# OPTIONAL: if omitted, the app auto-detects the current origin at runtime,
# which works correctly for both local dev and production.
# Only set this if auto-detection gives the wrong URL for your deployment.
#
# VITE_SUPABASE_REDIRECT_URL=https://ashutosh3021.github.io/Kasrat
# VITE_SUPABASE_REDIRECT_URL=http://localhost:5173/Kasrat
# VITE_SUPABASE_REDIRECT_URL=
